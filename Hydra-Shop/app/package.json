{
  "name": "hydra-shop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "if [ \"$NODE_ENV\" != \"production\" ] && [ -d ../.git ]; then husky; fi",
    "dev": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && node node_modules/next/dist/bin/next dev --turbopack",
    "build": "node -e \"require('fs').rmSync('.next/dev/types',{recursive:true,force:true})\" && next build && node scripts/cleanup-maps.mjs",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "analyze": "ANALYZE=true next build",
    "bundle-analyzer": "npx @next/bundle-analyzer",
    "performance:audit": "lighthouse http://localhost:3000 --output=html --output-path=./reports/lighthouse.html",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "optimize-images": "node scripts/optimize-images.mjs"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@reduxjs/toolkit": "^2.11.2",
    "@sentry/nextjs": "^10.52.0",
    "@tanstack/react-query": "^5.0.0",
    "arcane-vault-ui": "link:../theme",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.23.26",
    "lucide-react": "^0.562.0",
    "next": "16.2.3",
    "next-pwa": "^5.6.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-intersection-observer": "^9.5.0",
    "react-redux": "^9.2.0",
    "sharp": "^0.34.5",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.0.0",
    "@playwright/test": "^1.58.1",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^10.2.12",
    "@storybook/blocks": "^8.6.14",
    "@storybook/nextjs": "^10.2.12",
    "@storybook/react": "^10.2.12",
    "@storybook/test": "^8.6.15",
    "@storybook/test-runner": "^0.24.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/jest": "^29.0.0",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chromatic": "^15.2.0",
    "critters": "^0.0.25",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "lighthouse": "^13.1.0",
    "lint-staged": "^15.0.0",
    "picocolors": "^1.1.1",
    "prettier": "^3.0.0",
    "react-doctor": "^0.1.6",
    "storybook": "^10.2.12",
    "tailwindcss": "^4",
    "typescript": "5.9.3",
    "webpack-bundle-analyzer": "^4.9.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,css,md}": [
      "prettier --write"
    ]
  },
  "browserslist": [
    "baseline widely available"
  ]
}
