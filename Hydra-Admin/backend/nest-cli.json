{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": ".",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "webpackConfigPath": "webpack.config.cjs",
    "tsConfigPath": "tsconfig.json",
    "builder": "swc"
  },
  "projects": {
    "api": {
      "type": "application",
      "root": ".",
      "entryFile": "main",
      "sourceRoot": "src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.json"
      }
    },
    "catalog": {
      "type": "application",
      "root": "apps/catalog",
      "entryFile": "main",
      "sourceRoot": "apps/catalog/src",
      "compilerOptions": {
        "tsConfigPath": "apps/catalog/tsconfig.app.json"
      }
    },
    "commerce": {
      "type": "application",
      "root": "apps/commerce",
      "entryFile": "main",
      "sourceRoot": "apps/commerce/src",
      "compilerOptions": {
        "tsConfigPath": "apps/commerce/tsconfig.app.json"
      }
    },
    "engage": {
      "type": "application",
      "root": "apps/engage",
      "entryFile": "main",
      "sourceRoot": "apps/engage/src",
      "compilerOptions": {
        "tsConfigPath": "apps/engage/tsconfig.app.json"
      }
    },
    "admin-svc": {
      "type": "application",
      "root": "apps/admin-svc",
      "entryFile": "main",
      "sourceRoot": "apps/admin-svc/src",
      "compilerOptions": {
        "tsConfigPath": "apps/admin-svc/tsconfig.app.json"
      }
    },
    "database": {
      "type": "library",
      "root": "libs/database",
      "entryFile": "index",
      "sourceRoot": "libs/database/src",
      "compilerOptions": {
        "tsConfigPath": "libs/database/tsconfig.lib.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "queue": {
      "type": "library",
      "root": "libs/queue",
      "entryFile": "index",
      "sourceRoot": "libs/queue/src",
      "compilerOptions": {
        "tsConfigPath": "libs/queue/tsconfig.lib.json"
      }
    },
    "auth": {
      "type": "library",
      "root": "libs/auth",
      "entryFile": "index",
      "sourceRoot": "libs/auth/src",
      "compilerOptions": {
        "tsConfigPath": "libs/auth/tsconfig.lib.json"
      }
    },
    "auth-svc": {
      "type": "application",
      "root": "apps/auth",
      "entryFile": "main",
      "sourceRoot": "apps/auth/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth/tsconfig.app.json"
      }
    },
    "notify": {
      "type": "application",
      "root": "apps/notify",
      "entryFile": "main",
      "sourceRoot": "apps/notify/src",
      "compilerOptions": {
        "tsConfigPath": "apps/notify/tsconfig.app.json"
      }
    },
    "mtgsrc": {
      "type": "application",
      "root": "apps/mtgsrc",
      "entryFile": "main",
      "sourceRoot": "apps/mtgsrc/src",
      "compilerOptions": {
        "tsConfigPath": "apps/mtgsrc/tsconfig.app.json"
      }
    }
  }
}
