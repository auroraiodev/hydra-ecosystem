# ============================================================
# hydra-admin — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env with real values.
# ============================================================

# --- Server ---
PORT=3002
FRONTEND_URL=http://localhost:3000,http://localhost:3001
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_SELLER_URL=http://localhost:3003

# --- Backend API (used by Next.js frontend) ---
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:3002/api
NEXT_PUBLIC_API_URL=http://localhost:3002/api
API_URL_INTERNAL=http://localhost:3002/api

# --- Auth Service (embedded in API gateway) ---
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:3002
AUTH_SERVICE_URL=http://localhost:3002

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/hydra
DIRECT_URL=postgresql://user:password@localhost:5432/hydra

# --- Auth / JWT ---
JWT_SECRET=your-secret-here
JWT_EXPIRES_IN=7d

# --- MercadoPago ---
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_CLIENT_ID=
MERCADOPAGO_CLIENT_SECRET=
MERCADOPAGO_WEBHOOK_SECRET=

# --- Push Notifications (Web Push / VAPID) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@hydracollect.com

# --- External APIs ---
GEMINI_API_KEY=
OCR_SPACE_API_KEY=

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Storage (Garage/S3) ---
STORAGE_S3_ENDPOINT=https://s3.your-domain.com
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
STORAGE_S3_REGION=garage
STORAGE_S3_BUCKET=hydra-images
STORAGE_S3_PUBLIC_URL=https://files.your-domain.com

# --- NOTE: All backend modules are embedded (monolithic mode).
# Microservice URLs below are unused unless running in microservice mode.
# --- Cookie Encryption (admin/seller dashboards) ---
# AES-256-GCM — min 32 chars
COOKIE_SECRET=your-32-char-secret-here
