# ============================================================
# hydra-admin — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local with real values.
# ============================================================

# --- App URLs ---
# URL of the customer marketplace (hydra-fe). Used to redirect non-admin users.
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
# URL of the seller dashboard (hydra-seller). Used to redirect SELLER-role users.
NEXT_PUBLIC_SELLER_URL=http://localhost:3003

# --- Backend API ---
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:3002/api
NEXT_PUBLIC_API_URL=http://localhost:3002/api

# --- Auth Service (hydra-auth) ---
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:3004

# --- Session / JWT ---
# Must match JWT_EXPIRES_IN on the backend. Formats: 30m, 4h, 7d. Default: 1h
JWT_EXPIRES_IN=7d

# Cookie encryption key — AES-256-GCM (min 32 chars).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=your-32-char-secret-here
