    "@types/d3-timer": "^3.0.2",
    "@types/d3-transition": "^3.0.2",
    "@types/node": "^22",
    "@types/phoenix": "^1.5.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/socket.io": "^3.0.2",
    "@types/ws": "^8.5.5",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.0.0",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.0.0",
    "postcss": "^8.5",
    "prettier": "^3.0.0",
    "react-doctor": "^0.1.6",
    "socket.io": "^4.8.3",
    "tailwindcss": "^4.1.9",
    "tw-animate-css": "^1.3.3",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  }
}
