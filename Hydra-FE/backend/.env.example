# ============================================================
# hydra-be — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env with real values.
# ============================================================

# --- Server ---
PORT=3002
FRONTEND_URL=http://localhost:3000,http://localhost:3001
REVALIDATE_SECRET=your-revalidate-secret-here

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/hydra
DIRECT_URL=postgresql://user:password@localhost:5432/hydra

# --- Auth / JWT ---
JWT_SECRET=your-secret-here  # generate: openssl rand -base64 64
# Session lifetime. Formats: 30m, 4h, 7d. Default: 1h
JWT_EXPIRES_IN=7d

# --- Auth Service (hydra-auth) ---
AUTH_SERVICE_URL=http://localhost:3004

# --- MercadoPago ---
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_CLIENT_ID=
MERCADOPAGO_CLIENT_SECRET=
MERCADOPAGO_WEBHOOK_SECRET=

# --- Push Notifications (Web Push / VAPID) ---
# Generate: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@hydracollect.com

# --- External APIs ---
GEMINI_API_KEY=
OCR_SPACE_API_KEY=

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Storage (Garage/S3) ---
STORAGE_S3_ENDPOINT=https://s3.your-domain.com
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
STORAGE_S3_REGION=garage
STORAGE_S3_BUCKET=hydra-images
STORAGE_S3_PUBLIC_URL=https://files.your-domain.com

# --- Microservices ---
# MTGSRC (Hareruya proxy). Local: http://localhost:3006 | Docker: http://hydra-mtgsrc:3006
MTGSRC_SERVICE_URL=http://localhost:3006
# CATALOG (Catalog service). Local: http://localhost:3010 | Docker: http://hydra-catalog:3010
CATALOG_SERVICE_URL=http://localhost:3010
# COMMERCE (Order & checkout service). Local: http://localhost:3011 | Docker: http://hydra-commerce:3011
COMMERCE_SERVICE_URL=http://localhost:3011
# ENGAGE (Notifications, reviews, chat service). Local: http://localhost:3012 | Docker: http://hydra-engage:3012
ENGAGE_SERVICE_URL=http://localhost:3012
# ADMIN-SVC (Admin dashboard service). Local: http://localhost:3013 | Docker: http://hydra-admin-svc:3013
ADMIN_SVC_URL=http://localhost:3013
# Optional fallback if primary URL fails (network errors only)
# MTGSRC_FALLBACK_URL=http://hydra-mtgsrc:3006
# Optional — has a hardcoded fallback user ID built in
IMPORTATION_API_USER_ID=

