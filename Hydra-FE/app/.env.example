# ============================================================
# hydra-fe — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local with real values.
# ============================================================

# --- Backend API ---
# For local development only. In Docker, set BACKEND_API_URL at runtime.
NEXT_PUBLIC_API_URL=http://localhost:3002
# Server-side backend URL (Docker: http://hydra-be:3002). Overrides NEXT_PUBLIC_API_URL on the server.
BACKEND_API_URL=http://localhost:3002
NEXT_PUBLIC_APP_URL=http://localhost:3000
REVALIDATE_SECRET=your-revalidate-secret-here

# --- Session / JWT ---
# Must match JWT_EXPIRES_IN on the backend. Formats: 30m, 4h, 7d. Default: 1h
JWT_EXPIRES_IN=7d

# --- Auth Service (hydra-auth) ---
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:3004
