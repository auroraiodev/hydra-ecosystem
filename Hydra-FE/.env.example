# ============================================================
# Hydra-FE — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env with real values.
# ============================================================

# --- Server ---
PORT=3002
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://127.0.0.1:3002
BACKEND_API_URL=http://127.0.0.1:3002
NEXT_PUBLIC_APP_URL=http://localhost:3000
REVALIDATE_SECRET=your-revalidate-secret-here

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://user:password@localhost:5432/hydra
DIRECT_URL=postgresql://user:password@localhost:5432/hydra

# --- Auth / JWT ---
JWT_SECRET=your-secret-here  # generate: openssl rand -base64 64
JWT_EXPIRES_IN=7d

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3002/auth/google/callback

# --- MercadoPago ---
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# --- Push Notifications (Web Push / VAPID) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@hydracollect.com

# --- External APIs ---
GEMINI_API_KEY=

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Storage (Garage/S3) ---
STORAGE_S3_ENDPOINT=
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
STORAGE_S3_REGION=garage
STORAGE_S3_BUCKET=hydra-images
STORAGE_S3_PUBLIC_URL=
